# Telegram (достаточно TOKEN или TELEGRAM_TOKEN)
TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Путь к файлу резюме (относительно корня проекта или абсолютный)
RESUME_PATH=./assets/resume.pdf

# --- ИИ: указать ключи только для тех провайдеров, которые нужны ---
# Бот выберет API с наименьшим ping среди заданных.

# OpenAI (GPT-4o-mini)
OPENAI_API_KEY=sk-...

# Yandex GPT
YANDEX_API_KEY=...
YANDEX_FOLDER_ID=...

# GigaChat
GIGACHAT_API_KEY=...
GIGACHAT_CREDENTIALS=...
