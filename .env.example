# Telegram (достаточно TOKEN или TELEGRAM_TOKEN)
TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Путь к файлу резюме (относительно корня проекта или абсолютный)
RESUME_PATH=./assets/resume.pdf

# --- ИИ: указать ключи только для тех провайдеров, которые нужны ---
# Бот выберет API с наименьшим ping среди заданных.

# OpenAI (GPT-4o-mini)
OPENAI_API_KEY=sk-...

# Yandex GPT
YANDEX_API_KEY=...
YANDEX_FOLDER_ID=...

# GigaChat — developers.sber.ru → GigaChat API → создать проект
# Вариант 1: ключ авторизации (Base64) из «Данные авторизации» в ЛК
GIGACHAT_CREDENTIALS=
# Вариант 2: Client ID и Secret по отдельности (кодируются автоматически)
# GIGACHAT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# GIGACHAT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
